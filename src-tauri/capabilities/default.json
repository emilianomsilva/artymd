{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "window-state:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/**/**" },
        { "path": "$HOME/**/**/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$APPDATA/**" },
        { "path": "$TEMP/**" },
        { "path": "/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/**/**" },
        { "path": "$HOME/**/**/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$APPDATA/**" },
        { "path": "/**" }
      ]
    }
  ]
}
