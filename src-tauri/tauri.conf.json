{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ArtyMD",
  "version": "0.1.3",
  "identifier": "com.artymd.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ArtyMD",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "msi", "dmg", "app"],
    "linux": {
      "deb": {
        "desktopTemplate": "desktop-template.desktop"
      }
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkdn", "mdwn", "mdtxt", "mdtext"],
        "mimeType": "text/markdown",
        "name": "Markdown Document",
        "description": "Markdown text document",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
